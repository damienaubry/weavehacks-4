{
  "name": "weavehacks-4",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "ask": "pnpm --filter @weavehacks/api ask",
    "health": "pnpm --filter @weavehacks/api health",
    "seed": "pnpm --filter @weavehacks/api seed",
    "prep": "pnpm --filter @weavehacks/api prep",
    "baseline": "pnpm --filter @weavehacks/api baseline",
    "compare": "pnpm --filter @weavehacks/api compare",
    "demo": "pnpm --filter @weavehacks/api demo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
