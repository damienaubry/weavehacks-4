# ─────────────────────────────────────────────────────────────────────────────
# Brigade (WeaveHacks 4) — environment
# Copy to .env (start.sh does this for you) and fill in keys.
#
#   Runtime agents = OpenAI and/or W&B Inference (both OpenAI-compatible).
#   Observability  = W&B Weave (MANDATORY) — same WANDB_API_KEY as W&B Inference.
#
# Credits fund the RUNTIME PRODUCT AGENTS, not build tooling.
# The deterministic scoreboard (pnpm seed / compare / demo) runs with NO keys at all.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime provider (RESOLVED: wandb — see CLAUDE.md) ──
# Which provider product agents use: wandb (default) | openai (switchable fallback).
# The one W&B key below powers BOTH Weave and W&B Inference, so W&B credits fund the agents.
RUNTIME_PROVIDER=wandb

# ── OpenAI ($50 credits → runtime agents) ──
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Default model when RUNTIME_PROVIDER=openai (e.g. gpt-4o, gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# ── W&B: ONE key powers BOTH Weave tracing AND W&B Inference ($50 credits) ──
# Get it at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
# Model id. Run `pnpm --filter @weavehacks/api models` to list ids your key can use.
WANDB_INFERENCE_MODEL=zai-org/GLM-5.1
# Optional usage attribution: "entity/project" (sent as the openai-project header).
WANDB_PROJECT=

# ── Weave (observability — mandatory) ──
WEAVE_PROJECT=brigade

# ── Redis (shared agent state + pub/sub + scores/feedback/vector memory) ──
REDIS_URL=redis://localhost:6379

# ── Web shell → API ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEAVE_PROJECT=brigade
