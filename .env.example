# ─────────────────────────────────────────────────────────────────────────────
# WeaveHacks 4 — environment
# Copy to .env (start.sh does this for you) and fill in keys.
#
# IMPORTANT: OpenAI + W&B credits fund the RUNTIME AGENTS INSIDE THE PRODUCT,
# not build tooling. Don't point codegen tools at these keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime inference (product agents) ──
# OpenAI is the day-one provider for ALL runtime agents.
OPENAI_API_KEY=

# ── W&B Weave (observability — MANDATORY) ──
# Used to trace every agent call + every conflict resolution, and to run the
# solo-vs-team scoreboard. Get a key at https://wandb.ai/authorize
WANDB_API_KEY=
# Weave project name (shows up in the W&B UI).
WEAVE_PROJECT=weavehacks-4

# ── Second runtime provider — OPEN DECISION #3 (do NOT enable without team sign-off) ──
# W&B Inference is OpenAI-compatible: same client, different base URL. Only worth
# wiring if it maps to ROLES (cheap/fast for high-frequency agents, stronger for
# verifier/orchestrator). Left here for convenience; not active by default.
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1

# ── Redis (shared agent state + pub/sub) ──
REDIS_URL=redis://localhost:6379

# ── Web shell → API ──
NEXT_PUBLIC_API_URL=http://localhost:3001
